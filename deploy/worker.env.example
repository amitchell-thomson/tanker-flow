# Worker-1 .env — the second-egress ingester on the Oracle Cloud Always Free VM.
# Copy to `.env` in the repo root on that VM. Worker-0 (home) keeps its existing
# .env unchanged EXCEPT for setting WORKER_COUNT=2 (see the runbook).

# --- Sharding identity --------------------------------------------------------
WORKER_ID=1
WORKER_COUNT=2

# --- Stage-3c terminal-bbox catch-all -----------------------------------------
# Replace THIS worker's scan-rotation connection with a single geofence
# subscription over the terminal-approach boxes, injecting any in-scope LNG
# carrier (FSRUs excluded) heard there — the free safety-net for the cold-start /
# crowd-out carriers MMSI filtering misses. Enable on exactly ONE worker (this
# second egress); worker-0 keeps its scan rotation. Default off.
BBOX_CATCHALL=true

# --- Singletons OFF: worker-0 (home) owns scoring / port_events / VF spend -----
# Leaving these unset would also default to off for WORKER_ID!=0, but set them
# explicitly so the intent is unambiguous. RUN_VF_RESCUE *must* stay false here —
# the ingester refuses to start otherwise (shared VF credit budget, no double-spend).
RUN_SCORING=false
RUN_PORT_EVENTS=false
RUN_VF_RESCUE=false

# --- DB over Tailscale --------------------------------------------------------
# The home node's Tailscale (100.x) IP — NOT a public address. The DB is never
# exposed to the internet; it is reachable only across the tailnet (see runbook).
DB_HOST=100.64.0.1
DB_PORT=5432
DB_NAME=tanker_flow
DB_USER=tanker_user
DB_PASSWORD=__same_as_home__

# --- AISstream ----------------------------------------------------------------
# The same key is fine: the 3-conn cap is per *IP*, and this worker egresses
# Oracle's public IP (its own fresh 3-conn bucket). ALT is only useful if you
# later want per-key quota isolation.
AISSTREAM_API_KEY=__your_key__
AISSTREAM_API_KEY_ALT=__your_alt_key__

# --- VF unused on this worker (RUN_VF_RESCUE=false) but the field must exist ---
VF_API_KEY=
EIA_API_KEY=
